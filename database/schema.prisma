generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id                 String           @id
  displayName        String?
  gender             String?
  birthYear          Int?
  heightCm           Float?
  weightKg           Float?
  activityLevel      String           @default("sedentary")
  calorieGoal        String           @default("maintain")
  dailyCalorieTarget Int?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  settings           AppSettings?
  scans              IngredientScan[]
  recipes            Recipe[]
  foodLogs           FoodLog[]
  water              WaterEntry[]
  waterTargets       WaterTarget[]
  exercise           ExerciseLog[]
  sleep              SleepLog[]
  weight             WeightLog[]
}

model AppSettings {
  id                   String   @id @default(cuid())
  profileId            String   @unique
  locale               String   @default("en")
  theme                String   @default("light")
  defaultWaterTargetMl Int      @default(2000)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  profile              Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId])
}

model IngredientScan {
  id                String                 @id @default(cuid())
  profileId         String
  imageName         String
  imageMimeType     String
  overallConfidence String
  uncertaintyNoteEn String
  uncertaintyNoteZh String
  confirmedAt       DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  profile           Profile                @relation(fields: [profileId], references: [id], onDelete: Cascade)
  ingredients       RecognizedIngredient[]
  pairings          EpicurePairing[]
  recipes           Recipe[]

  @@index([profileId, createdAt])
}

model RecognizedIngredient {
  id              String         @id @default(cuid())
  scanId          String
  normalizedName  String
  displayNameEn   String
  displayNameZh   String
  estimatedAmount String
  estimatedCalories Int?
  confidence      String
  notes           String
  position        Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  scan            IngredientScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
}

model EpicurePairing {
  id                  String         @id @default(cuid())
  scanId              String
  sourceIngredient    String
  suggestedIngredient String
  score               Float?
  category            String?
  reasonEn            String
  reasonZh            String
  createdAt           DateTime       @default(now())
  scan                IngredientScan @relation(fields: [scanId], references: [id], onDelete: Cascade)

  @@index([scanId])
  @@index([sourceIngredient])
}

model Recipe {
  id                          String                    @id @default(cuid())
  profileId                   String
  sourceScanId                String?
  cuisineStyle                String
  difficulty                  String
  referenceImageQuery         String?
  referenceImageUrl           String?
  referenceImageSourceTitle   String?
  referenceImageSourceUrl     String?
  referenceImageProvider      String?
  referenceImageAiReason      String?
  referenceImageCropXPercent  Float?
  referenceImageCropYPercent  Float?
  referenceImageCropZoom      Float?
  estimatedCookingMinutes     Int
  servings                    Int
  estimatedCaloriesPerServing Int?
  isFavorite                  Boolean                   @default(false)
  createdAt                   DateTime                  @default(now())
  updatedAt                   DateTime                  @updatedAt
  profile                     Profile                   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  sourceScan                  IngredientScan?           @relation(fields: [sourceScanId], references: [id], onDelete: SetNull)
  translations                RecipeTranslation[]
  ingredients                 RecipeIngredient[]
  steps                       RecipeStep[]
  tips                        RecipeTip[]
  missingIngredients          RecipeMissingIngredient[]
  foodLogs                    FoodLog[]

  @@index([profileId])
  @@index([sourceScanId])
  @@index([isFavorite])
  @@index([createdAt])
}

model RecipeImageCache {
  id             String   @id @default(cuid())
  cacheKey       String   @unique
  query          String
  url            String
  sourceTitle    String
  sourceUrl      String
  provider       String
  cropXPercent   Float?
  cropYPercent   Float?
  cropZoom       Float?
  aiSelected     Boolean  @default(false)
  aiReason       String?
  hits           Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  lastUsedAt     DateTime @default(now())

  @@index([query])
  @@index([lastUsedAt])
}

model AppErrorLog {
  id          String   @id @default(cuid())
  profileId   String?
  source      String
  severity    String   @default("error")
  message     String
  path        String?
  method      String?
  statusCode  Int?
  stack       String?
  userAgent   String?
  detailsJson String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([profileId, createdAt])
  @@index([source, createdAt])
}

model RecipeTranslation {
  id                  String   @id @default(cuid())
  recipeId            String
  locale              String
  title               String
  shortDescription    String
  nutritionDisclaimer String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  recipe              Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, locale])
  @@index([recipeId])
}

model RecipeIngredient {
  id                     String  @id @default(cuid())
  recipeId               String
  normalizedName         String
  nameEn                 String
  nameZh                 String
  amount                 String
  isRecognizedIngredient Boolean @default(false)
  isOptional             Boolean @default(false)
  position               Int
  recipe                 Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model RecipeStep {
  id               String  @id @default(cuid())
  recipeId         String
  stepNumber       Int
  estimatedMinutes Int?
  instructionEn    String
  instructionZh    String
  recipe           Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model RecipeTip {
  id        String @id @default(cuid())
  recipeId  String
  position  Int
  contentEn String
  contentZh String
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model RecipeMissingIngredient {
  id             String  @id @default(cuid())
  recipeId       String
  normalizedName String
  nameEn         String
  nameZh         String
  isOptional     Boolean @default(true)
  recipe         Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model FoodLog {
  id           String   @id @default(cuid())
  profileId    String
  recipeId     String?
  date         String
  mealCategory String
  nameEn       String
  nameZh       String?
  calories     Int?
  proteinGrams Float?
  carbsGrams   Float?
  fatGrams     Float?
  notes        String?
  sourceType   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  profile      Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  recipe       Recipe?  @relation(fields: [recipeId], references: [id], onDelete: SetNull)

  @@index([profileId, date])
  @@index([profileId, mealCategory, date])
  @@index([recipeId])
}

model WaterEntry {
  id        String   @id @default(cuid())
  profileId String
  date      String
  amountMl  Int
  createdAt DateTime @default(now())
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, date])
}

model WaterTarget {
  id        String   @id @default(cuid())
  profileId String
  date      String
  targetMl  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
  @@index([profileId, date])
}

model ExerciseLog {
  id                       String   @id @default(cuid())
  profileId                String
  type                     String
  durationMinutes          Int
  estimatedCaloriesBurned  Int?
  date                     String
  notes                    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  profile                  Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, date])
}

model SleepLog {
  id        String   @id @default(cuid())
  profileId String
  date      String
  hours     Float
  quality   String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
  @@index([profileId, date])
}

model WeightLog {
  id        String   @id @default(cuid())
  profileId String
  date      String
  weightKg  Float
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, date])
  @@index([profileId, date])
}
